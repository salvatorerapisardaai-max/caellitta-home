# Ignore environment files and secrets
.env
.env.local
.env.*
.env.production
.env.*.local
# Node modules
node_modules/
# Vercel build output and config
.vercel/
# Build outputs
dist/
build/
# OS files
.DS_Store
Thumbs.db
# IDEs
.vscode/
.idea/
# Database dumps and local data
*.sqlite
*.db
*.sql
*.dump
# Keys and credentials
*.key
*.pem
# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Temporary
tmp/
.cache/
# Screenshots / exported guest data (keep only anonymized mockups in public showcase)
*.png
*.jpg
*.jpeg
*.gif
